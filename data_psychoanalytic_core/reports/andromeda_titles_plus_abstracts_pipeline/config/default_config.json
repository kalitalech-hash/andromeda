{
  "pipeline_name": "andromeda_titles_plus_abstracts_pipeline",
  "andromeda_version": "0.4",
  "corpus_id": "pepweb_or_other_titles_abstracts_corpus",
  "required_columns": [
    "article_id",
    "title",
    "year"
  ],
  "text_columns": [
    "title",
    "abstract"
  ],
  "deduplication_keys": [
    "doi",
    "article_id",
    "article_url",
    "title_year_hash"
  ],
  "language": "en",
  "year_min": null,
  "year_max": null,
  "periods": [
    {
      "label": "pre_1945",
      "start": 0,
      "end": 1944,
      "order": 1
    },
    {
      "label": "1945_1969",
      "start": 1945,
      "end": 1969,
      "order": 2
    },
    {
      "label": "1970_1989",
      "start": 1970,
      "end": 1989,
      "order": 3
    },
    {
      "label": "1990_2009",
      "start": 1990,
      "end": 2009,
      "order": 4
    },
    {
      "label": "2010_2025",
      "start": 2010,
      "end": 2025,
      "order": 5
    }
  ],
  "term_extraction": {
    "ngram_range": [
      1,
      3
    ],
    "min_df": 2,
    "max_df": 0.85,
    "max_features": 5000,
    "top_terms_per_article": 20,
    "stopwords_file": "templates/stopwords_domain.txt"
  },
  "cooccurrence": {
    "min_edge_weight": 3,
    "top_nodes_for_plot": 40
  },
  "ethics": {
    "store_restricted_abstracts_in_public_repo": false,
    "store_full_text": false,
    "mirror_pdfs": false,
    "prefer_derived_features": true
  }
}